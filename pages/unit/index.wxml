<!-- 单位换算页面 -->
<view class="unit-page">
  <!-- 顶部类别 Tab -->
  <scroll-view class="category-tabs" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="category-list">
      <view
        class="category-item {{activeCategory === item.key ? 'category-active' : ''}}"
        wx:for="{{categories}}"
        wx:key="key"
        data-category="{{item.key}}"
        bindtap="onCategoryTap"
      >
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 换算区域 -->
  <view class="convert-area">
    <!-- 源单位 -->
    <view class="unit-card" bindtap="onSourceUnitPicker">
      <view class="card-header">
        <text class="unit-label">从</text>
        <text class="unit-select">{{sourceUnitName || '请选择'}}</text>
        <text class="arrow-down">▼</text>
      </view>
      <view class="card-value">
        <text class="value-text">{{sourceValue}}</text>
      </view>
    </view>

    <!-- 交换按钮 -->
    <view class="swap-bar">
      <view class="swap-btn" bindtap="onSwap">
        <text class="swap-icon">⇅</text>
      </view>
    </view>

    <!-- 目标单位 -->
    <view class="unit-card" bindtap="onTargetUnitPicker">
      <view class="card-header">
        <text class="unit-label">到</text>
        <text class="unit-select">{{targetUnitName || '请选择'}}</text>
        <text class="arrow-down">▼</text>
      </view>
      <view class="card-value">
        <text class="value-text">{{targetValue}}</text>
      </view>
    </view>

    <!-- 常用换算参考 -->
    <view class="ref-area" wx:if="{{commonRefs.length > 0}}">
      <text class="ref-title">常用换算参考</text>
      <view class="ref-item" wx:for="{{commonRefs}}" wx:key="*this">
        <text class="ref-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 数字键盘 -->
  <view class="numpad-area">
    <view class="numpad-row">
      <view class="numpad-key" data-digit="7" bindtap="onDigitTap"><text>7</text></view>
      <view class="numpad-key" data-digit="8" bindtap="onDigitTap"><text>8</text></view>
      <view class="numpad-key" data-digit="9" bindtap="onDigitTap"><text>9</text></view>
    </view>
    <view class="numpad-row">
      <view class="numpad-key" data-digit="4" bindtap="onDigitTap"><text>4</text></view>
      <view class="numpad-key" data-digit="5" bindtap="onDigitTap"><text>5</text></view>
      <view class="numpad-key" data-digit="6" bindtap="onDigitTap"><text>6</text></view>
    </view>
    <view class="numpad-row">
      <view class="numpad-key" data-digit="1" bindtap="onDigitTap"><text>1</text></view>
      <view class="numpad-key" data-digit="2" bindtap="onDigitTap"><text>2</text></view>
      <view class="numpad-key" data-digit="3" bindtap="onDigitTap"><text>3</text></view>
    </view>
    <view class="numpad-row">
      <view class="numpad-key numpad-func" bindtap="onClear"><text>C</text></view>
      <view class="numpad-key" data-digit="0" bindtap="onDigitTap"><text>0</text></view>
      <view class="numpad-key numpad-func" bindtap="onDecimalTap"><text>.</text></view>
    </view>
  </view>

  <!-- 单位选择器 -->
  <unit-picker
    visible="{{showPicker}}"
    title="选择单位"
    options="{{pickerOptions}}"
    selected="{{pickerSelected}}"
    bind:select="onPickerSelect"
    bind:close="onPickerClose"
  />
</view>
