/* numpad 组件样式 */
.numpad {
  display: flex;
  flex-direction: column;
  padding: 12rpx 16rpx 20rpx;
  gap: 18rpx;
  background-color: #F7F7F7;
}

.key-row {
  display: flex;
  flex-direction: row;
  gap: 18rpx;
  flex: 1;
}

.key {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  transition: opacity 0.1s;
  min-height: 110rpx;
}

.key-label {
  font-size: 40rpx;
  font-weight: 800;
  user-select: none;
}

/* 数字键 */
.key-num {
  background-color: #FFFFFF;
  color: #1C1C1E;
}

.key-num.key-pressed {
  opacity: 0.6;
}

/* 功能键 (C, ⌫, %) */
.key-func {
  background-color: #FFFFFF;
  color: #FF6900;
}

.key-func.key-pressed {
  opacity: 0.6;
}

/* 运算符键 (+, −, ×, ÷) */
.key-operator {
  background-color: #FFFFFF;
  color: #FF6900;
}

.key-operator.key-pressed {
  opacity: 0.6;
}

/* 等号键 */
.key-equals {
  background-color: #FF6900;
  color: #FFFFFF;
}

.key-equals.key-pressed {
  opacity: 0.6;
}

/* 科学模式 */
.key-small {
  min-height: 96rpx;
}

.numpad-scientific .key {
  min-height: 96rpx;
  border-radius: 28rpx;
}

.key-label-small {
  font-size: 30rpx;
}

/* 图标键 */
.key-icon {
  width: 44rpx;
  height: 44rpx;
}

.key-icon-backspace {
  width: 48rpx;
  height: 48rpx;
}

.numpad-scientific .key {
  min-height: 100rpx;
}

/* 2nd 按钮激活态（橙色底白字） */
.key-active {
  background-color: #FF6900 !important;
  color: #FFFFFF !important;
}
