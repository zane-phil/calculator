<view class="calc-page">

  <top-nav active="{{currentTab}}" bind:switchTab="onSwitchTab" />

  <block wx:if="{{currentTab === 'calc'}}">
    <display-area
      exprDisplay="{{exprDisplay}}"
      previewText="{{previewText}}"
      resultDisplay="{{resultDisplay}}"
      historyText="{{historyText}}"
      showResult="{{showResult}}"
      error="{{error}}"
    />

    <numpad
      layout="{{layout}}"
      hasInput="{{exprDisplay.length > 0}}"
      bind:digit="onDigit"
      bind:operator="onOperator"
      bind:function="onFunction"
      bind:clear="onClear"
      bind:backspace="onBackspace"
      bind:equals="onEquals"
      bind:percent="onPercent"
      bind:paren="onParen"
      bind:constant="onConstant"
      bind:toggleLayout="onToggleLayout"
      bind:degChange="onDegChange"
      bind:decimal="onDecimal"
    />
  </block>

  <block wx:elif="{{currentTab === 'convert'}}">
    <view class="tool-grid">
      <view
        class="tool-item"
        wx:for="{{tools}}"
        wx:key="key"
        data-url="{{item.url}}"
        bindtap="onToolTap"
      >
        <view class="tool-icon-box">
          <image wx:if="{{item.iconType === 'svg'}}" class="tool-icon-svg" src="{{item.icon}}" />
          <text wx:else class="tool-icon-text">{{item.icon}}</text>
        </view>
        <text class="tool-label">{{item.name}}</text>
      </view>
    </view>
  </block>

</view>