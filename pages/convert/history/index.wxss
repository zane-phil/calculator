/* 历史记录页面样式 */
.history-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F7F7F7;
}

.history-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background-color: #F7F7F7;
  border-bottom: 1rpx solid var(--color-divider);
}

.header-count {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

.clear-btn {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.clear-text {
  font-size: var(--font-body);
  color: var(--color-error);
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: var(--font-h3);
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
}

/* 历史列表 */
.history-list {
  flex: 1;
  padding: 16rpx 32rpx;
}

.history-item {
  background-color: #FFFFFF;
  border-radius: var(--radius-card);
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.history-item:active {
  background-color: #F2F2F7;
}

.item-body {
  display: flex;
  flex-direction: column;
  margin-bottom: 12rpx;
}

.item-expression {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
  margin-bottom: 4rpx;
}

.item-result {
  font-size: var(--font-h3);
  color: var(--color-text-primary);
  font-weight: 500;
  text-align: right;
}

.item-footer {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.item-time {
  font-size: var(--font-small);
  color: var(--color-text-secondary);
}

.item-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 28rpx;
  opacity: 0.5;
}
