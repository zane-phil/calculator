/* 换算入口列表页 */
.convert-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F7F7F7;
}

.tool-grid {
  flex: 1;
  padding: 24rpx 32rpx;
}

.tool-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
}

.tool-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background-color: #FFF5EB;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tool-icon {
  font-size: 40rpx;
}

.tool-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.tool-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 6rpx;
}

.tool-desc {
  font-size: 24rpx;
  color: #8E8E93;
}

.tool-arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.arrow-icon {
  font-size: 36rpx;
  color: #C7C7CC;
}
