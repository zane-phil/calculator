.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F7F7F7;
}

.bmi-scroll {
  flex: 1;
  overflow-y: auto;
}

.bmi-content {
  padding: 40rpx 44rpx;
}

/* 标签 */
.label {
  font-size: 28rpx;
  color: #8E8E93;
  margin-bottom: 16rpx;
}

.placeholder-style {
  color: #C7C7CC;
  font-size: 34rpx;
}

/* 输入框 */
.input-field {
  font-size: 40rpx;
  font-weight: 500;
  color: #1C1C1E;
  border-bottom: 2rpx solid #E5E5EA;
  padding: 12rpx 0 16rpx;
  width: 100%;
  height: auto;
  min-height: 56rpx;
  line-height: 56rpx;
}

.field-block {
  margin-bottom: 48rpx;
}

/* 性别选择 */
.gender-group {
  display: flex;
  gap: 24rpx;
}

.gender-item {
  flex: 1;
  height: 100rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.gender-active {
  border-color: #FF6900;
  background: #FFF5EB;
}

.gender-icon {
  font-size: 40rpx;
}

.gender-text {
  font-size: 30rpx;
  color: #1C1C1E;
  font-weight: 500;
}

/* BMI说明 */
.bmi-info {
  margin-top: 32rpx;
}

.info-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 12rpx;
}

.info-desc {
  font-size: 26rpx;
  color: #8E8E93;
  line-height: 1.7;
}

/* 计算按钮 */
.btn-calc {
  width: 100%;
  height: 96rpx;
  background: #FF6900;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 60rpx;
}

.btn-calc:active {
  opacity: 0.8;
}
