<!-- 个税计算页面 -->
<scroll-view class="tax-page" scroll-y enhanced show-scrollbar="{{false}}">
  <top-nav mode="back" title="个税计算" />
  <view class="tax-form">
    <!-- 税前月收入 -->
    <view class="form-card">
      <text class="form-label">税前月收入（元）</text>
      <input
        class="form-input"
        type="digit"
        placeholder="输入税前月工资..."
        value="{{salary}}"
        bindinput="onSalaryInput"
      />
    </view>

    <!-- 五险一金基数 -->
    <view class="form-card">
      <text class="form-label">五险一金缴纳基数（默认 = 税前收入）</text>
      <input
        class="form-input"
        type="digit"
        placeholder="输入缴纳基数..."
        value="{{insuranceBase}}"
        bindinput="onInsuranceBaseInput"
      />
    </view>

    <!-- 五险一金比例 -->
    <view class="form-card">
      <view class="form-card-header" bindtap="toggleInsurance">
        <text class="form-label">五险一金缴纳比例</text>
        <text class="toggle-icon">{{insuranceExpanded ? '▲' : '▼'}}</text>
      </view>
      <view class="insurance-list" wx:if="{{insuranceExpanded}}">
        <view class="insurance-item" wx:for="{{insuranceRates}}" wx:key="key">
          <text class="insurance-name">{{item.name}}</text>
          <text class="insurance-rate">{{item.rate}}%</text>
          <switch
            checked="{{item.checked}}"
            data-key="{{item.key}}"
            bindchange="onInsuranceSwitch"
            color="#FF6900"
          />
        </view>
      </view>
    </view>

    <!-- 专项附加扣除 -->
    <view class="form-card">
      <view class="form-card-header" bindtap="toggleDeductions">
        <text class="form-label">专项附加扣除</text>
        <text class="toggle-icon">{{deductionsExpanded ? '▲' : '▼'}}</text>
      </view>
      <view class="deduction-list" wx:if="{{deductionsExpanded}}">
        <view class="deduction-item" wx:for="{{deductions}}" wx:key="key">
          <view class="deduction-info">
            <text class="deduction-name">{{item.name}}</text>
            <text class="deduction-desc">{{item.desc}}</text>
          </view>
          <!-- 住房租金特殊处理 -->
          <block wx:if="{{item.key === 'housingRent'}}">
            <view class="deduction-control" data-key="{{item.key}}" bindtap="onRentLevel">
              <text class="deduction-value">{{item.amount > 0 ? '¥' + item.amount : '未选择'}}</text>
            </view>
          </block>
          <!-- 子女/婴幼儿数量 -->
          <block wx:elif="{{item.maxPerChild}}">
            <view class="deduction-counter">
              <view class="counter-btn" data-key="{{item.key}}" data-delta="-1" bindtap="onDeductionCount">
                <text class="counter-text">−</text>
              </view>
              <text class="counter-num">{{item.childCount}}</text>
              <view class="counter-btn" data-key="{{item.key}}" data-delta="1" bindtap="onDeductionCount">
                <text class="counter-text">+</text>
              </view>
            </view>
          </block>
          <!-- 其他扣除 -->
          <block wx:else>
            <view class="deduction-control" data-key="{{item.key}}" bindtap="onDeductionSwitch">
              <text class="deduction-value {{item.amount > 0 ? 'deduction-enabled' : ''}}">
                {{item.amount > 0 ? '¥' + item.amount : '未选择'}}
              </text>
            </view>
          </block>
        </view>
      </view>
    </view>

    <!-- 计算按钮 -->
    <view class="calc-btn" bindtap="onCalculate">
      <text class="calc-btn-text">计算个税</text>
    </view>

    <!-- 计算结果 -->
    <result-card
      title="计算结果"
      rows="{{resultRows}}"
      visible="{{showResult}}"
    />
  </view>
</scroll-view>
