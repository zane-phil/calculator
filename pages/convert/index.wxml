<!-- 换算入口列表页 -->
<view class="convert-page">
  <!-- 顶部导航（计算 | 换算） -->
  <top-nav active="convert" />

  <!-- 工具入口网格 -->
  <view class="tool-grid">
    <view
      class="tool-card"
      wx:for="{{tools}}"
      wx:key="key"
      data-url="{{item.url}}"
      bindtap="onToolTap"
    >
      <view class="tool-icon-wrap">
        <text class="tool-icon">{{item.icon}}</text>
      </view>
      <view class="tool-info">
        <text class="tool-name">{{item.name}}</text>
        <text class="tool-desc">{{item.desc}}</text>
      </view>
      <view class="tool-arrow">
        <text class="arrow-icon">›</text>
      </view>
    </view>
  </view>
</view>
