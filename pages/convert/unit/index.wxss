/* 单位换算页面样式 */
.unit-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #D1D1D6;
}

/* 类别 Tab */
.category-tabs {
  background-color: #D1D1D6;
  white-space: nowrap;
  padding: 8rpx 0;
}

.category-list {
  display: flex;
  flex-direction: row;
  padding: 0 16rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  margin: 0 6rpx;
  border-radius: 8rpx;
  background-color: #C7C7CC;
}

.category-item text {
  font-size: var(--font-body);
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.category-active {
  background-color: var(--color-primary);
}

.category-active text {
  color: #FFFFFF;
  font-weight: 500;
}

/* 换算区域 */
.convert-area {
  flex: 1;
  padding: 24rpx 32rpx;
}

.unit-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 2rpx;
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.unit-label {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
  margin-right: 12rpx;
}

.unit-select {
  font-size: var(--font-body);
  color: var(--color-text-primary);
  flex: 1;
}

.arrow-down {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.card-value {
  display: flex;
  justify-content: flex-end;
}

.value-text {
  font-size: 56rpx;
  color: var(--color-text-primary);
}

.swap-bar {
  display: flex;
  justify-content: center;
  padding: 8rpx 0;
  margin: 8rpx 0;
}

.swap-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.swap-icon {
  font-size: 32rpx;
  color: var(--color-primary);
}

/* 常用换算参考 */
.ref-area {
  background-color: rgba(255,255,255,0.8);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 32rpx;
}

.ref-title {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.ref-item {
  padding: 8rpx 0;
}

.ref-text {
  font-size: var(--font-body);
  color: var(--color-text-primary);
}

/* 数字键盘 */
.numpad-area {
  background-color: #D1D1D6;
  padding: 4rpx;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.numpad-row {
  display: flex;
  flex-direction: row;
  gap: 2rpx;
}

.numpad-key {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  min-height: 100rpx;
  border-radius: 4rpx;
}

.numpad-key:active {
  background-color: #E5E5EA;
}

.numpad-key text {
  font-size: 40rpx;
  color: var(--color-text-primary);
}

.numpad-func {
  background-color: #C7C7CC;
}

.numpad-func:active {
  background-color: #B0B0B8;
}
