/* 个税计算页面样式 */
.tax-page {
  height: 100vh;
  background-color: #F7F7F7;
}

.tax-form {
  padding: 24rpx 32rpx;
  padding-bottom: 60rpx;
}

.form-card {
  background-color: #FFFFFF;
  border-radius: var(--radius-card);
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.form-card-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.form-label {
  font-size: var(--font-body);
  color: var(--color-text-primary);
  font-weight: 500;
  display: block;
  margin-bottom: 16rpx;
}

.form-card-header .form-label {
  margin-bottom: 0;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 40rpx;
  color: var(--color-text-primary);
  border-bottom: 2rpx solid var(--color-divider);
  padding: 8rpx 0;
}

.toggle-icon {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.insurance-list {
  margin-top: 16rpx;
}

.insurance-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 0;
}

.insurance-item:not(:last-child) {
  border-bottom: 1rpx solid #F2F2F7;
}

.insurance-name {
  flex: 1;
  font-size: var(--font-body);
  color: var(--color-text-primary);
}

.insurance-rate {
  font-size: var(--font-body);
  color: var(--color-text-secondary);
  margin-right: 24rpx;
}

.deduction-list {
  margin-top: 16rpx;
}

.deduction-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
}

.deduction-item:not(:last-child) {
  border-bottom: 1rpx solid #F2F2F7;
}

.deduction-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.deduction-name {
  font-size: var(--font-body);
  color: var(--color-text-primary);
}

.deduction-desc {
  font-size: var(--font-small);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.deduction-control {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background-color: #F2F2F7;
}

.deduction-value {
  font-size: var(--font-body);
  color: var(--color-text-secondary);
}

.deduction-enabled {
  color: var(--color-primary);
  font-weight: 500;
}

.deduction-counter {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.counter-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background-color: #F2F2F7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.counter-text {
  font-size: 32rpx;
  color: var(--color-text-primary);
}

.counter-num {
  font-size: var(--font-body);
  color: var(--color-text-primary);
  min-width: 32rpx;
  text-align: center;
}

.calc-btn {
  background-color: var(--color-primary);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  margin: 24rpx 0;
}

.calc-btn:active {
  background-color: var(--color-primary-dark);
}

.calc-btn-text {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 600;
}
