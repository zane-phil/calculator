<!-- 科学计算器页面 -->
<view class="calc-page">
  <!-- 顶部操作栏 -->
  <view class="calc-header">
    <view class="header-left">
      <view class="deg-toggle" bindtap="toggleDegMode">
        <text class="deg-text {{degMode ? 'deg-active' : ''}}">DEG</text>
        <text class="deg-divider">|</text>
        <text class="deg-text {{!degMode ? 'deg-active' : ''}}">RAD</text>
      </view>
    </view>
    <view class="header-center">
      <view class="history-btn" bindtap="goToHistory">
        <text class="header-icon">🕐</text>
      </view>
    </view>
    <view class="header-right" bindtap="goToBasic">
      <text class="header-link">基础</text>
    </view>
  </view>

  <!-- 显示区域 -->
  <display-area
    expression="{{expression}}"
    result="{{result}}"
    error="{{error}}"
  />

  <!-- 科学模式键盘 -->
  <numpad
    layout="scientific"
    degMode="{{degMode}}"
    bind:digit="onDigit"
    bind:operator="onOperator"
    bind:function="onFunction"
    bind:constant="onConstant"
    bind:paren="onParen"
    bind:clear="onClear"
    bind:backspace="onBackspace"
    bind:equals="onEquals"
    bind:percent="onPercent"
    bind:negate="onNegate"
    bind:decimal="onDecimal"
  />
</view>
