<!-- display 组件 - 计算器显示屏 -->
<view class="display {{error ? 'display-error' : ''}}">
  <!-- 表达式区域 -->
  <scroll-view
    class="expression-area"
    scroll-x
    scroll-left="{{scrollLeft}}"
    enhanced
    show-scrollbar="{{false}}"
  >
    <text class="expression-text">{{expression || '0'}}</text>
  </scroll-view>

  <!-- 结果区域 -->
  <view class="result-area">
    <text class="result-text {{error ? 'result-error' : ''}}">
      {{error ? '错误' : result}}
    </text>
  </view>
</view>
