<!-- numpad 组件 -->
<view class="numpad numpad-{{layout}}">
  <!-- 基础模式 (5行 × 4列) -->
  <block wx:if="{{layout === 'basic'}}">
    <view class="key-row" wx:for="{{basicKeys}}" wx:key="index">
      <view
        wx:for="{{item}}" wx:for-item="key" wx:key="label"
        class="key {{key.class}}"
        data-key="{{key}}"
        data-type="{{key.type}}"
        hover-class="key-pressed"
        bindtap="onKeyTap"
      >
        <text class="key-label">{{key.label}}</text>
      </view>
    </view>
  </block>

  <!-- 科学模式 (7行 × 6列) -->
  <block wx:if="{{layout === 'scientific'}}">
    <view class="key-row" wx:for="{{scientificKeys}}" wx:key="index">
      <view
        wx:for="{{item}}" wx:for-item="key" wx:key="label"
        class="key key-small {{key.class}}"
        data-key="{{key}}"
        data-type="{{key.type}}"
        hover-class="key-pressed"
        bindtap="onKeyTap"
      >
        <text class="key-label key-label-small">{{key.label}}</text>
      </view>
    </view>
  </block>
</view>
