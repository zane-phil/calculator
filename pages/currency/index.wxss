/* 汇率换算页面样式 */
.currency-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #D1D1D6;
}

.convert-area {
  flex: 1;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
}

.currency-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 2rpx;
}

.currency-card:active {
  background-color: #F2F2F7;
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.currency-flag {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.currency-name {
  font-size: var(--font-body);
  color: var(--color-text-primary);
  flex: 1;
}

.currency-code {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
  margin-right: 8rpx;
}

.arrow-down {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.card-amount {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
}

.amount-text {
  font-size: 56rpx;
  font-weight: 400;
  color: var(--color-text-primary);
}

.swap-bar {
  display: flex;
  justify-content: center;
  padding: 8rpx 0;
  margin: 8rpx 0;
}

.swap-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.swap-icon {
  font-size: 32rpx;
  color: var(--color-primary);
}

.update-info {
  padding: 16rpx;
  margin-top: auto;
}

.update-text {
  font-size: var(--font-small);
  color: var(--color-text-secondary);
  text-align: center;
}

/* 数字键盘 */
.numpad-area {
  background-color: #D1D1D6;
  padding: 4rpx;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.numpad-row {
  display: flex;
  flex-direction: row;
  gap: 2rpx;
}

.numpad-key {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  min-height: 100rpx;
  border-radius: 4rpx;
}

.numpad-key:active {
  background-color: #E5E5EA;
}

.numpad-key text {
  font-size: 40rpx;
  color: var(--color-text-primary);
}

.numpad-func {
  background-color: #C7C7CC;
}

.numpad-func:active {
  background-color: #B0B0B8;
}
