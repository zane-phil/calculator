/* unit-picker 组件样式 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.picker-mask-show {
  opacity: 1;
  visibility: visible;
}

.picker-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 60vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
}

.picker-panel-show {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--color-divider);
}

.picker-title {
  font-size: var(--font-body);
  font-weight: 600;
  color: var(--color-text-primary);
}

.picker-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background-color: #F2F2F7;
}

.picker-close-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.picker-body {
  height: 400rpx;
  overflow-y: auto;
  padding: 16rpx 0;
}

.picker-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx 32rpx;
  position: relative;
}

.picker-item:active {
  background-color: #F2F2F7;
}

.picker-item-selected {
  background-color: #FFF3E6;
}

.picker-item-flag {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.picker-item-name {
  font-size: var(--font-body);
  color: var(--color-text-primary);
  flex: 1;
}

.picker-item-code {
  font-size: var(--font-caption);
  color: var(--color-text-secondary);
  margin-right: 16rpx;
}

.picker-check {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
}
