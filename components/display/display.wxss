/* display 组件样式 */
.display {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 24rpx 32rpx;
  min-height: 200rpx;
  background-color: #F7F7F7;
}

.expression-area {
  width: 100%;
  white-space: nowrap;
}

.expression-text {
  display: block;
  font-size: var(--font-h2);
  color: var(--color-text-secondary);
  text-align: right;
  min-height: 50rpx;
  line-height: 50rpx;
  word-break: keep-all;
}

.result-area {
  display: flex;
  justify-content: flex-end;
  align-items: flex-end;
  margin-top: 8rpx;
}

.result-text {
  font-size: var(--font-h1);
  font-weight: 500;
  color: var(--color-text-primary);
  text-align: right;
  line-height: 90rpx;
  word-break: break-all;
}

.result-error {
  color: var(--color-error);
  font-size: 56rpx;
}

.display-error .result-text {
  color: var(--color-error);
}
